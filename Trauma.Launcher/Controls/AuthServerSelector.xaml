<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Trauma.Launcher.Controls"
             x:Class="Trauma.Launcher.Controls.AuthServerSelector"
             x:DataType="controls:AuthServerSelector">
    <StackPanel Margin="40" MinWidth="220" MinHeight="400">
        <TextBlock TextAlignment="Center"
            Classes="NanoHeadingMedium" Margin="8"
            Text="Auth Server"
            ToolTip.Tip="Pick the authentication server your account belongs to. You can add custom ones in the launcher settings."/>

        <Separator/>

        <ScrollViewer>
            <StackPanel Name="ServerList" Spacing="8" Margin="0 12 0 0"/> <!-- populated in Update -->
        </ScrollViewer>

        <Button Click="OpenChangeServersWindow" Content="Change Servers"/>
    </StackPanel>
</UserControl>
